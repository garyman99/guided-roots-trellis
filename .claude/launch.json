{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "api",
      "runtimeExecutable": "node",
      "runtimeArgs": ["apps/api/src/server.ts"],
      "port": 8787,
      "env": {
        "LAB_DRIVER": "docker",
        "DOCKER_HOST": "npipe:////./pipe/docker_engine",
        "LAB_DOCKER_CPUS": "2",
        "LAB_DOCKER_MEMORY": "1g",
        "LAB_DOCKER_PIDS": "512"
      }
    },
    {
      "name": "web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--workspace", "@trellis/web", "run", "dev"],
      "port": 5173
    }
  ]
}
