# ── Trellis API ──────────────────────────────────────────────────────────
PORT=8787

# Lab isolation driver:
#   local  — temp-dir + real shell on the host. Dev/POC only, NOT isolation.
#   docker — one container per session (build lab images first, see README).
LAB_DRIVER=local

# Instructor provider:
#   mock    — deterministic, offline, free (default)
#   openai  — any OpenAI-compatible /chat/completions endpoint
INSTRUCTOR_PROVIDER=mock
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Event storage: SQLite file, or `off` for in-memory (nothing persisted).
TRELLIS_PERSISTENCE=on
TRELLIS_DB_PATH=./data/trellis.db

# Admin surface (/api/admin/*): when set, every admin route requires this as
# a bearer token (the /admin page asks for it once and stores it locally).
# Unset = open — acceptable only for the local/household POC.
TRELLIS_ADMIN_TOKEN=

# ── Trellis web (Vite reads VITE_* at build/dev time) ────────────────────
# Auth0 (SPA app, Authorization Code + PKCE). Allowed callback URL must
# include <origin>/callback; allowed logout URL must include <origin>.
VITE_AUTH0_DOMAIN=
VITE_AUTH0_CLIENT_ID=
VITE_AUTH0_AUDIENCE=
# Local development bypass: "true" shows the "Continue as …" profile buttons
# (local developer, Eva) on the landing page (also auto-enabled in dev builds
# when Auth0 is unset). Profiles live in apps/web/src/auth.ts.
VITE_AUTH_BYPASS=true
# Auth0 users whose email is listed here (comma-separated) get the admin
# flag, i.e. the /admin operator surface. Bypass profiles declare it inline.
VITE_ADMIN_EMAILS=
