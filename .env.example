# ── Trellis API ──────────────────────────────────────────────────────────
PORT=8787
# Web dev server only: where the vite proxy forwards /api and /ws. Must
# match the api's PORT. Set both when 8787 is taken (e.g. PORT=8788 for the
# api, API_PORT=8788 for the web dev server).
#API_PORT=8787

# Lab isolation driver:
#   local  — temp-dir + real shell on the host. Dev/POC only, NOT isolation.
#   docker — one container per session (build lab images first, see README).
LAB_DRIVER=local

# ── Model providers (role-scoped, ADR-0006) ──────────────────────────────
# Each role (GUIDE_ / SIMULATOR_ / EVALUATOR_) selects its provider + model
# independently:
#   mock               — deterministic, offline, free (default)
#   anthropic          — Anthropic Messages API (requires *_MODEL + a key)
#   openai-compatible  — any /chat/completions endpoint, incl. LOCAL models
#                        (requires *_MODEL; key optional for localhost)
#   fake               — scripted test provider
# No model names are hardcoded: LLM providers fail at boot without *_MODEL.
GUIDE_PROVIDER=mock
GUIDE_MODEL=
#GUIDE_BASE_URL=                       # override endpoint for this role only
ANTHROPIC_API_KEY=
# Local model example (LM Studio/Ollama/vLLM):
#GUIDE_PROVIDER=openai-compatible
#GUIDE_BASE_URL=http://localhost:1234/v1
#GUIDE_MODEL=qwen2.5-coder-14b-instruct

# Other roles (same provider vocabulary; used by tools/simulate.mjs and
# tools/evaluate.mjs — the product server only needs the Guide):
#SIMULATOR_PROVIDER=anthropic
#SIMULATOR_MODEL=
#EVALUATOR_PROVIDER=anthropic
#EVALUATOR_MODEL=

# Legacy names (still honored for the Guide role; role-scoped vars win):
#   INSTRUCTOR_PROVIDER=mock|openai, OPENAI_BASE_URL/OPENAI_API_KEY/OPENAI_MODEL
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=

# Model telemetry (ADR-0006): run manifests + invocation JSONL land here.
# Git-ignored local evidence; CI uploads instead. Relative to the API cwd.
TRELLIS_ARTIFACTS_DIR=artifacts

# Event storage: SQLite file, or `off` for in-memory (nothing persisted).
TRELLIS_PERSISTENCE=on
TRELLIS_DB_PATH=./data/trellis.db

# Admin surface (/api/admin/*): when set, every admin route requires this as
# a bearer token (the /admin page asks for it once and stores it locally).
# Unset = open — acceptable only for the local/household POC.
TRELLIS_ADMIN_TOKEN=

# ── Trellis web (Vite reads VITE_* at build/dev time) ────────────────────
# Auth0 (SPA app, Authorization Code + PKCE). Allowed callback URL must
# include <origin>/callback; allowed logout URL must include <origin>.
VITE_AUTH0_DOMAIN=
VITE_AUTH0_CLIENT_ID=
VITE_AUTH0_AUDIENCE=
# Local development bypass: "true" shows the "Continue as …" profile buttons
# (local developer, Eva) on the landing page (also auto-enabled in dev builds
# when Auth0 is unset). Profiles live in apps/web/src/auth.ts.
VITE_AUTH_BYPASS=true
# Auth0 users whose email is listed here (comma-separated) get the admin
# flag, i.e. the /admin operator surface. Bypass profiles declare it inline.
VITE_ADMIN_EMAILS=

# Guide narration. Browser speech is dependency-free; voice-tools uses the
# local Orpheus service and can route inference to either LM Studio machine.
VITE_TTS_PROVIDER=browser
#VITE_TTS_BASE_URL=http://127.0.0.1:48720
#VITE_TTS_VOICE=tara
#VITE_TTS_LM_STUDIO_TARGET=headless
